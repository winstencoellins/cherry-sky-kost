# Backend API base URL (no trailing slash).
# Used by the /api/backend proxy and server-side session checks.
#
# Development (local Elysia backend on port 8000):
API_URL=http://localhost:8000
# NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Production (set in Vercel — API_URL is server-only, no rebuild to change):
# API_URL=https://cherry-sky-kost-backend-production.up.railway.app
#
# Staging:
# API_URL=https://api-staging.cherryskykost.com
#
# Browser traffic always goes through /api/backend on the frontend origin so
# session cookies stay first-party. API_URL tells the proxy where to forward.
