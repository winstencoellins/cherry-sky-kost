# Backend API base URL (no trailing slash).
# Used by apiFetch, Better Auth, and server-side session checks.
#
# Development (local Elysia backend on port 8000):
NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Staging (set in your hosting provider's staging/preview environment):
# NEXT_PUBLIC_API_URL=https://api-staging.cherryskykost.com
#
# Production (set in your hosting provider's production environment):
# NEXT_PUBLIC_API_URL=https://api.cherryskykost.com
